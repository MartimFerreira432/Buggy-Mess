      m_Calls: []
  m_text: "\xC9 um inseto de dimens\xF5es muito pequenas, com 14 a 21 mm, de cor
    acastanhada ou esverdeada. Tem como habitat preferencial matos abertos mediterr\xE2nicos
    e prados secos e pedregosos at\xE9 grandes altitudes, podendo ser avistado tamb\xE9m
    em estepes cereal\xEDferas. \r\nDistribui-se pelo sudoeste da Europa (Portugal,
    Espanha e Fran\xE7a) e \xE9 considerada uma esp\xE9cie rara. Em Portugal a sua
    presen\xE7a conhecida encontra-se, neste momento, restrita \xE0 Serra da Estrela,
    apesar de anteriormente ter sido avistado em Coimbra, na serra da Gardunha e
    no Parque Natural de Montesinho.\r\nEsta esp\xE9cie est\xE1 amea\xE7ada devido
    \xE0 ocorr\xEAncia de inc\xEAndios florestais, que tendem a intensificar-se com
    as altera\xE7\xF5es clim\xE1ticas. A prolifera\xE7\xE3o de plantas invasoras,
    como as ac\xE1cias, e o aumento de \xE1reas de mato, s\xE3o tamb\xE9m fatores
    que podem levar ao aumento dos inc\xEAndios e consequente diminui\xE7\xE3o desta
    esp\xE9cie.\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
