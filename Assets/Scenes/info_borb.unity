  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\xC9 uma borboleta cujas asas apresentam uma colora\xE7\xE3o alaranjada-avermelhada
    com manchas negras, e \xE9 considerada um importante indicador da qualidade ecol\xF3gica
    das turfeiras e zonas h\xFAmidas europeias. Vive principalmente em turfeiras,
    p\xE2ntanos \xE1cidos e zonas h\xFAmidas com vegeta\xE7\xE3o de urze. Em Portugal
    podemos encontr\xE1-la sobretudo em zonas montanhosas h\xFAmidas do norte e centro
    do pa\xEDs. Esta esp\xE9cie encontra-se em decl\xEDnio (20%-50%) na maioria dos
    pa\xEDses europeus. Das principais amea\xE7as \xE0 esp\xE9cie podemos destacar
    os inc\xEAndios florestais, a  utiliza\xE7\xE3o de agroqu\xEDmicos na agricultura
    e a drenagem e aterro de zonas h\xFAmidas. "
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_fontSharedMaterials: []
  m_fontMaterial: {fileID: 0}
